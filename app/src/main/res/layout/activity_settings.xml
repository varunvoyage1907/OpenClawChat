<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Settings"
                android:textColor="@color/primary_cyan"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ==================== OpenClaw Section ==================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenClaw Connection"
            android:textColor="@color/primary_cyan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- OpenClaw URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenClaw URL"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etOpenClawUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="http://your-server:port/v1/chat/completions"
            android:inputType="textUri"
            android:padding="14dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_gray"
            android:layout_marginBottom="16dp" />

        <!-- Auth Token -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gateway Token"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etOpenClawToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="Your OpenClaw gateway token"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_gray"
            android:layout_marginBottom="16dp" />

        <!-- Test Connection -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Connection"
            android:textColor="@color/white"
            app:backgroundTint="@color/secondary_purple"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hint_gray"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- ==================== Sarvam AI Section ==================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sarvam AI (Voice)"
            android:textColor="@color/primary_cyan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Natural Indian voice for STT &amp; TTS"
            android:textColor="@color/hint_gray"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- Sarvam API Key -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sarvam AI API Key"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etSarvamApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:hint="sk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxx"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_gray"
            android:layout_marginBottom="16dp" />

        <!-- Voice Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voice (Bulbul v3)"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerVoice"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Default Language -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Default Language (for text chat)"
            android:textColor="@color/label_gray"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerLanguage"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Speech Pace -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Speech Pace"
                android:textColor="@color/label_gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvPaceValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.3x"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekBarPace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="15"
            android:progress="8"
            android:progressTint="@color/primary_cyan"
            android:thumbTint="@color/primary_cyan"
            android:layout_marginBottom="16dp" />

        <!-- Test Voice -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTestVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Voice"
            android:textColor="@color/white"
            app:backgroundTint="@color/secondary_purple"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_volume_on"
            app:iconGravity="textStart"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvVoiceTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/hint_gray"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- ==================== Smart Glasses Section ==================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smart Glasses"
            android:textColor="@color/primary_cyan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect Oudmon/HeyCyan smart glasses for vision"
            android:textColor="@color/hint_gray"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- Glasses Connection Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewGlassesStatus"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/status_indicator_disconnected" />

            <TextView
                android:id="@+id/tvGlassesStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Not Connected"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvGlassesBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hint_gray"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Scan/Connect/Disconnect Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanGlasses"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan"
                android:textColor="@color/white"
                app:backgroundTint="@color/secondary_purple"
                app:cornerRadius="8dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDisconnectGlasses"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnect"
                android:textColor="@color/white"
                app:backgroundTint="@color/error_red"
                app:cornerRadius="8dp"
                android:enabled="false"
                android:alpha="0.5" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvGlassesInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap Scan to find nearby glasses"
            android:textColor="@color/hint_gray"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- ==================== System Prompt Section ==================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="System Prompt"
                android:textColor="@color/primary_cyan"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnResetPrompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset"
                android:textColor="@color/primary_cyan"
                android:textSize="13sp"
                android:padding="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etSystemPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="120dp"
            android:background="@drawable/bg_input"
            android:hint="Customize AI personality..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:padding="14dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hint_gray"
            android:layout_marginBottom="32dp" />

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/primary_cyan"
            app:cornerRadius="12dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
